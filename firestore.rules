rules_version = '2';

// ==========================================================================
// Triangulation — Firestore Security Rules (client-side model)
//
// This build uses NO Firebase Auth and NO Cloud Functions (free Spark plan).
// Authentication is performed by the app against `users` / `credentials`.
// Because requests are unauthenticated at the Firestore layer, these rules
// cannot enforce per-user identity — the APPLICATION enforces roles.
//
// Passwords are stored only as salted SHA-256 hashes in `credentials`
// (never plaintext). UCEEM responses are constrained so they can never carry
// respondent-identifying fields (anonymity is enforced here).
//
// ⚠️ TRADE-OFF: without Firebase Auth the data is broadly accessible to anyone
// holding the public web config. This is an intentional choice for the free
// plan. For stronger isolation use the Firebase-Auth / Functions build (Blaze).
// ==========================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // Reference data & profiles — app-managed.
    match /departments/{id}      { allow read, write: if true; }
    match /users/{id}            { allow read, write: if true; }
    match /credentials/{id}      { allow read, write: if true; }
    match /usernameIndex/{id}    { allow read, write: if true; }
    match /studentGroups/{id}    { allow read, write: if true; }
    match /students/{id}         { allow read, write: if true; }
    match /evaluations/{id}      { allow read, write: if true; }
    match /uceemCampaigns/{id}   { allow read, write: if true; }

    // Anonymous UCEEM responses: readable (aggregation), create-only, and the
    // document may contain ONLY assessment fields — never a respondent uid,
    // student id, name, email, phone, ip or user-agent. Enforced here.
    match /uceemResponses/{id} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasOnly([
        'anonymousResponseId', 'campaignId', 'targetUserId', 'targetRole',
        'targetName', 'departmentId', 'academicYear', 'semester', 'group',
        'answers', 'calculatedScores', 'createdAt'
      ]);
      allow update, delete: if false;
    }

    // Everything else is denied.
    match /{document=**} { allow read, write: if false; }
  }
}
